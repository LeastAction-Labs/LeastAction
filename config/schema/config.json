{
    "columns": [
        
        
        {
            "name": "name",
            "datatype": "string",
            "required": true,
            "min_length": 1,
            "max_length": 255,
            "regex": "^[a-zA-Z0-9_\\-\\s]+$",
            "description": "Config name with alphanumeric characters, spaces, hyphens, and underscores",
            "tab": {
                "name": "Overview",
                "order": 1
            }
        },
        {
            "name": "description",
            "datatype": "string",
            "required": false,
            "max_length": 1000,
            "default": "",
            "description": "Optional config description",
            "tab": {
                "name": "Overview",
                "order": 2
            }
        },
        {
            "name": "config_type",
            "datatype": "enum",
            "enum_values": [
                "task",
                "UIaction",
                "taskAction",
                "workflow",
                "system",
                "connection"
            ],
            "required": true,
            "description": "Type of configuration",
            "tab": {
                "name": "Overview",
                "order": 3
            }
        },
        {
            "name": "content",
            "datatype": "object",
            "required": true,
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "description": "Configuration content as JSON object",
            "tab": {
                "name": "Overview",
                "order": 4
            },
            "sample_placeholder": {
                "defaults": {
                    "task": {
                        "total_retries": 0,
                        "retry_interval": 1
                    },
                    "taskControlActions": [],
                    "uiActions": []
                },
                "parameters": {},
                "partition": "",
                "git": {},
                "priority": [],
                "overridable": [],
                "not_overridable": {}
            }
        },
        {
            "name": "version_compatibility",
            "datatype": "object",
            "required": false,
            "description": "Which Core versions this item runs on. Uses glob patterns: \"0.*\" = any 0.x, \"1.2.*\" = any 1.2.x.",
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "sample_placeholder": {
                "core": [
                    "0.*"
                ]
            },
            "tab": {
                "name": "Version",
                "order": 1
            },
            "default": {
                "core": [
                    "0.*"
                ]
            },
            "properties": {
                "core": {
                    "type": "array",
                    "items": "string",
                    "description": "Version glob patterns, e.g. [\"0.*\", \"1.*\"]. Empty = all versions."
                }
            },
            "tooltip": "Specify core version globs in the core array.\n\nExamples:\n\u2022 [\"0.*\"] \u2014 any 0.x release\n\u2022 [\"0.*\", \"1.*\"] \u2014 0.x or 1.x\n\u2022 [\"1.2.*\"] \u2014 only 1.2.x\n\u2022 [] \u2014 compatible with all versions\n\nPatterns use wildcard (*) matching on each version segment.",
            "ui_display_name": "Version Compatibility"
        },
        {
            "name": "version_details",
            "datatype": "object",
            "required": false,
            "description": "Source, versioning, and publishing metadata. version field required for explicit versioning mode.",
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "tab": {
                "name": "Version",
                "order": 2
            },
            "default": {
                "version": "0.1.0",
                "versioning_mode": "implicit"
            },
            "properties": {
                "version": {
                    "type": "string",
                    "description": "Semantic version string, e.g. \"1.2.3\""
                },
                "versioning_mode": {
                    "type": "enum",
                    "enum_values": [
                        "implicit",
                        "explicit"
                    ],
                    "description": "implicit = auto-increment, explicit = manual version field required"
                },
                "channel": {
                    "type": "string",
                    "description": "Release channel, e.g. \"stable\", \"beta\""
                },
                "released_at": {
                    "type": "string",
                    "description": "ISO 8601 timestamp, e.g. \"2024-01-15T00:00:00Z\""
                },
                "changelog": {
                    "type": "string",
                    "description": "Release notes or changelog text"
                },
                "deprecated": {
                    "type": "boolean",
                    "description": "Mark this item as deprecated"
                }
            },
            "ui_display_name": "Version Details"
        },
        {
            "name": "image_url",
            "datatype": "string",
            "required": false,
            "max_length": 500,
            "description": "URL to a custom icon/image for this item in the marketplace",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Metadata",
                "order": 1
            }
        },
        {
            "name": "tags",
            "datatype": "array",
            "items": "string",
            "required": false,
            "max_items": 20,
            "description": "Searchable tags (e.g. \"python\", \"nlp\")",
            "tab": {
                "name": "Metadata",
                "order": 2
            }
        },
        {
            "name": "publisher",
            "datatype": "string",
            "required": false,
            "max_length": 100,
            "description": "Publishing entity. Use 'LeastAction' for official items.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Metadata",
                "order": 5
            }
        },
        {
            "name": "category",
            "datatype": "array",
            "required": false,
            "description": "Top-level category (e.g. 'AI', 'Data', 'DevOps')",
            "tab": {
                "name": "Metadata",
                "order": 3
            },
            "items": "string"
        },
        {
            "name": "division",
            "datatype": "string",
            "required": false,
            "max_length": 100,
            "description": "Division or team within the publisher organization",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Metadata",
                "order": 4
            }
        },
        {
            "name": "latest_version",
            "datatype": "boolean",
            "required": false,
            "description": "Pointer to the current latest semver string.",
            "tab": {
                "name": "Version",
                "order": 4
            }
        },
        {
            "name": "status",
            "datatype": "enum",
            "required": false,
            "description": "Lifecycle state of the config.",
            "tab": {
                "name": "Status",
                "order": 1
            },
            "enum_values": [
                "published",
                "deprecated",
                "archived",
                "security_warning",
                "security_hold",
                "draft"
            ]
        },
        {
            "name": "deprecated_at",
            "datatype": "datetime",
            "required": false,
            "description": "Timestamp when the item was deprecated.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 2
            }
        },
        {
            "name": "deprecated_reason",
            "datatype": "string",
            "required": false,
            "max_length": 1000,
            "description": "Human-readable reason for deprecation.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 3
            }
        },
        {
            "name": "successor_item_id",
            "datatype": "string",
            "required": false,
            "description": "ID of the replacement item, if applicable.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 4
            }
        },
        {
            "name": "sunset_date",
            "datatype": "datetime",
            "required": false,
            "description": "Date after which the item is no longer supported.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 5
            }
        }
    ],
    "projection_fields": [
        "name",
        "description",
        "content",
        "parent_laui",
        "project_laui"
    ],
    "ui_preview_fields": [
        "name",
        "description"
    ],
    "item_type_visual_config": {
        "icon": "SettingsApplications",
        "color": "#64748b"
    },
    "unique_constraints": [
        "parent_laui",
        "name"
    ],
    "indexes": [
        {
            "fields": [
                "name",
                "project_laui"
            ]
        },
        {
            "fields": [
                "name",
                "parent_laui"
            ]
        }
    ]
}