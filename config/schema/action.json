{
    "columns": [
        {
            "name": "name",
            "datatype": "string",
            "required": true,
            "min_length": 1,
            "max_length": 255,
            "regex": "^[a-zA-Z0-9_\\-]+\\.action$",
            "description": "Name of action with alphanumeric characters, hyphens and underscores and name must end with .operator",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Overview",
                "order": 1
            }
        },
        {
            "name": "description",
            "datatype": "string",
            "required": false,
            "max_length": 1000,
            "description": "Optional action description",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "viewerType": "markdown",
            "tab": {
                "name": "Overview",
                "order": 2
            }
        },
        {
            "name": "prompt",
            "datatype": "string",
            "required": false,
            "max_length": 10000,
            "description": "Prompt passed by the user for generating the action using AI",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "viewerType": "markdown",
            "tab": {
                "name": "Overview",
                "order": 3
            }
        },
        {
            "name": "guide_docs",
            "datatype": "string",
            "required": false,
            "max_length": 10000,
            "description": "Guide docs",
            "editorType": "monaco",
            "editorMonacoFormat": ".md",
            "viewerType": "markdown",
            "tab": {
                "name": "Overview",
                "order": 4
            }
        },
        {
            "name": "install_docs",
            "datatype": "string",
            "required": false,
            "max_length": 10000,
            "description": "Install docs",
            "editorType": "monaco",
            "editorMonacoFormat": ".md",
            "viewerType": "markdown",
            "tab": {
                "name": "Overview",
                "order": 5
            }
        },
        {
            "name": "codeblock",
            "datatype": "object",
            "required": true,
            "max_length": 10000,
            "description": "Code to execute",
            "editorType": "monaco",
            "editorMonacoFormat": "python"
        },
        {
            "name": "bashblock",
            "datatype": "object",
            "required": false,
            "max_length": 10000,
            "description": "bash code",
            "editorType": "monaco",
            "editorMonacoFormat": "python"
        },
        {
            "name": "connection",
            "datatype": "object",
            "required": false,
            "max_length": 10000,
            "description": "Sample connection schema for this action",
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "ui_display_name": "Sample Connection",
            "tab": {
                "name": "Overview",
                "order": 6
            }
        },
        {
            "name": "action_variables",
            "datatype": "object",
            "required": false,
            "max_length": 10000,
            "description": "Sample action variables for this action",
            "editorType": "monaco",
            "editorMonacoFormat": "text",
            "ui_display_name": "Sample Action Variables",
            "tab": {
                "name": "Overview",
                "order": 8
            }
        },
        {
            "name": "marketplace_laui",
            "datatype": "string",
            "required": false,
            "description": "Action Version, 0 is latest",
            "editorType": "textbox",
            "editorMonacoFormat": "text"
        },
        {
            "name": "version_compatibility",
            "datatype": "object",
            "required": false,
            "description": "Which Core versions this item runs on. Uses glob patterns: \"0.*\" = any 0.x, \"1.2.*\" = any 1.2.x.",
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "sample_placeholder": {
                "core": [
                    "0.*"
                ]
            },
            "tab": {
                "name": "Version",
                "order": 1
            },
            "default": {
                "core": [
                    "0.*"
                ]
            },
            "properties": {
                "core": {
                    "type": "array",
                    "items": "string",
                    "description": "Version glob patterns, e.g. [\"0.*\", \"1.*\"]. Empty = all versions."
                }
            },
            "tooltip": "Specify core version globs in the core array.\n\nExamples:\n\u2022 [\"0.*\"] \u2014 any 0.x release\n\u2022 [\"0.*\", \"1.*\"] \u2014 0.x or 1.x\n\u2022 [\"1.2.*\"] \u2014 only 1.2.x\n\u2022 [] \u2014 compatible with all versions\n\nPatterns use wildcard (*) matching on each version segment.",
            "ui_display_name": "Version Compatibility"
        },
        {
            "name": "version_details",
            "datatype": "object",
            "required": false,
            "description": "Source, versioning, and publishing metadata. version field required for explicit versioning mode.",
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "tab": {
                "name": "Version",
                "order": 2
            },
            "default": {
                "version": "0.1.0",
                "versioning_mode": "implicit"
            },
            "properties": {
                "version": {
                    "type": "string",
                    "description": "Semantic version string, e.g. \"1.2.3\""
                },
                "versioning_mode": {
                    "type": "enum",
                    "enum_values": [
                        "implicit",
                        "explicit"
                    ],
                    "description": "implicit = auto-increment, explicit = manual version field required"
                },
                "channel": {
                    "type": "string",
                    "description": "Release channel, e.g. \"stable\", \"beta\""
                },
                "released_at": {
                    "type": "string",
                    "description": "ISO 8601 timestamp, e.g. \"2024-01-15T00:00:00Z\""
                },
                "changelog": {
                    "type": "string",
                    "description": "Release notes or changelog text"
                },
                "deprecated": {
                    "type": "boolean",
                    "description": "Mark this item as deprecated"
                }
            },
            "ui_display_name": "Version Details"
        },
        {
            "name": "image_url",
            "datatype": "string",
            "required": false,
            "max_length": 500,
            "description": "URL to a custom icon/image for this item in the marketplace",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Metadata",
                "order": 1
            }
        },
        {
            "name": "tags",
            "datatype": "array",
            "items": "string",
            "required": false,
            "max_items": 20,
            "description": "Searchable tags (e.g. \"python\", \"nlp\")",
            "tab": {
                "name": "Metadata",
                "order": 2
            }
        },
        {
            "name": "publisher",
            "datatype": "string",
            "required": false,
            "max_length": 100,
            "description": "Publishing entity. Use 'LeastAction' for official items.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Metadata",
                "order": 5
            }
        },
        {
            "name": "category",
            "datatype": "array",
            "required": false,
            "description": "Top-level category (e.g. 'AI', 'Data', 'DevOps')",
            "tab": {
                "name": "Metadata",
                "order": 3
            },
            "items": "string"
        },
        {
            "name": "division",
            "datatype": "string",
            "required": false,
            "max_length": 100,
            "description": "Division or team within the publisher organization",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Metadata",
                "order": 4
            }
        },
        {
            "name": "verified",
            "datatype": "boolean",
            "required": false,
            "description": "True if verified/endorsed by the marketplace",
            "tab": {
                "name": "Metadata",
                "order": 6
            }
        },
        {
            "name": "latest_version",
            "datatype": "boolean",
            "required": false,
            "description": "Pointer to the current latest semver string.",
            "tab": {
                "name": "Version",
                "order": 4
            }
        },
        {
            "name": "status",
            "datatype": "enum",
            "required": false,
            "description": "Lifecycle state of the operator.",
            "tab": {
                "name": "Status",
                "order": 1
            },
            "enum_values": [
                "published",
                "deprecated",
                "archived",
                "security_warning",
                "security_hold",
                "draft"
            ]
        },
        {
            "name": "deprecated_at",
            "datatype": "datetime",
            "required": false,
            "description": "Timestamp when the item was deprecated.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 2
            }
        },
        {
            "name": "deprecated_reason",
            "datatype": "string",
            "required": false,
            "max_length": 1000,
            "description": "Human-readable reason for deprecation.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 3
            }
        },
        {
            "name": "successor_item_id",
            "datatype": "string",
            "required": false,
            "description": "ID of the replacement item, if applicable.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 4
            }
        },
        {
            "name": "sunset_date",
            "datatype": "datetime",
            "required": false,
            "description": "Date after which the item is no longer supported.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Status",
                "order": 5
            }
        },
        {
            "name": "validation_results",
            "datatype": "object",
            "required": false,
            "description": "Stored result of the last validation run.",
            "editorType": "monaco",
            "editorMonacoFormat": "json",
            "tab": {
                "name": "Validation",
                "order": 1
            }
        },
        {
            "name": "marketplace_sync_status",
            "datatype": "string",
            "required": false,
            "enum": [
                "up_to_date",
                "update_available",
                "deprecated",
                "security_warning"
            ],
            "description": "Sync state with the marketplace.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Validation",
                "order": 3
            }
        },
        {
            "name": "marketplace_last_checked",
            "datatype": "datetime",
            "required": false,
            "description": "Timestamp of the last marketplace sync check.",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Validation",
                "order": 4
            }
        }
    ],
    "projection_fields": [
        "name",
        "deleted_at",
        "parent_laui",
        "marketplace_laui",
        "project_laui"
    ],
    "ui_preview_fields": [
        "name",
        "description"
    ],
    "preview_fields": [
        "list"
    ],
    "item_type_visual_config": {
        "icon": "FlashOn",
        "color": "#eab308"
    },
    "unique_constraints": [
        "parent_laui",
        "name"
    ],
    "indexes": [
        {
            "fields": [
                "name",
                "project_laui"
            ]
        },
        {
            "fields": [
                "name",
                "parent_laui"
            ]
        }
    ],
    "form_excluded_fields": [
        "validation_results",
        "marketplace_sync_status",
        "marketplace_last_checked",
        "marketplace_laui"
    ]
}