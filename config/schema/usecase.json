            "description": "Name of usecase with alphanumeric characters, hyphens and underscores and name must end with .usecase",
            "editorType": "textbox",
            "editorMonacoFormat": "text",
            "tab": {
                "name": "Overview",
                "order": 1
            }
        },
        {
