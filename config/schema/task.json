{
  "columns": [
    {
      "name": "name",
      "datatype": "string",
      "required": true,
      "description": "Name of the task to be displayed.",
      "max_length": 255
    },
    {
      "name": "partition",
      "datatype": "string",
      "required": false,
      "default": "ALL"
    },
    {
      "name": "project_instance",
      "datatype": "string",
      "required": false,
      "description": "Cron or APIs will use this ip address for routing tasks",
      "default": null
    },
    {
      "name": "description",
      "datatype": "string",
      "required": false,
      "description": "Description of task",
      "default": null,
      "max_length": 10000
    },
    {
      "name": "operator_laui",
      "datatype": "ObjectId",
      "required": true,
      "description": "Id of the operator being executed"
    },
    {
      "name": "start_date",
      "datatype": "datetime",
      "required": false,
      "description": "The start datetime for the execution of task",
      "default": null
    },
    {
      "name": "end_date",
      "datatype": "datetime",
      "required": false,
      "description": "The end datetime for the execution of task",
      "default": null
    },
    {
      "name": "logical_date",
      "datatype": "datetime",
      "required": false,
      "description": "The next/current run logical datetime for the execution of task",
      "default": null
    },
    {
      "name":"retry_run_date",
      "datatype": "datetime",
      "required": false,
      "description": "The retry run datetime for the execution of a failed task",
      "default": null
    },
    {
      "name":"can_retry",
      "datatype": "boolean",
      "required": false,
      "description": "",
      "default": false
    },
    {
      "name": "frequency",
      "datatype": "string",
      "required": false,
      "description": "Cron expression for task execution frequency",
      "default": "ADHOC"
    },
    {
      "name": "data_interval_start",
      "datatype": "datetime",
      "required": false,
      "description": "The next/current run logical datetime for the execution of task, updated at start",
      "default": null
    },
    {
      "name": "data_interval_end",
      "datatype": "datetime",
      "required": false,
      "description": "The next/current run logical datetime + frequency for the execution of task, updated at start",
      "default": null
    },
    {
      "name": "prev_interval_start",
      "datatype": "datetime",
      "required": false,
      "description": "The previous run logical datetime for the execution of task, updated at end",
      "default": null
    },
    {
      "name": "prev_interval_end",
      "datatype": "datetime",
      "required": false,
      "description": "The previous run logical datetime + frequency for the execution of task, updated at end",
      "default": null
    },
    {
      "name": "last_run_date",
      "datatype": "datetime",
      "required": false,
      "description": "The date calculated based on start date and frequency",
      "default": null
      },
      {
      "name": "next_run_date",
      "datatype": "datetime",
      "required": false,
      "description": "The date calculated based on start date and frequency",
      "default": null
      },
    {
      "name": "task_instance_start_date",
      "datatype": "datetime",
      "required": false,
      "description": "The previous/current start run datetime for the execution of task, updated at start",
      "default": null
    },
    {
      "name": "task_instance_end_date",
      "datatype": "datetime",
      "required": false,
      "description": "The previous/current end run datetime for the execution of task, updated at end",
      "default": null
    },
    {
      "name": "last_system_updated_date",
      "datatype": "datetime",
      "required": false,
      "default": null
    },
    {
      "name": "latest_heartbeat",
      "datatype": "datetime",
      "required": false,
      "default": null
    },
    {
      "name": "last_run_output",
      "datatype": "object",
      "required": false,
      "default": null
    },
    {
      "name": "actions",
      "datatype": "object",
      "required": false,
      "default": {
        "create_actions": [],
        "pre_actions": [],
        "running_actions": [],
        "post_actions": []
      }
    },
    {
      "name": "actions_status",
      "datatype": "object",
      "required": false,
      "default": {
        "pre_actions": [],
        "running_actions": [],
        "post_actions": []
      }
    },
    {
      "name": "payload_laui",
      "datatype": "ObjectId",
      "required": false,
      "default": null
    },
    {
      "name": "payload",
      "datatype": "any",
      "required": false,
      "default": null
    },
    {
      "name": "connection_laui",
      "datatype": "ObjectId",
      "required": true
    },
    {
      "name": "state",
      "datatype": "enum",
      "enum_values": [
        "created",
        "scheduled",
        "queued_for_connection",
        "queued_in_redis",
        "running",
        "success",
        "error",
        "timeout",
        "cancelled",
        "fail"
      ],
      "required": false,
      "description": "The state of execution of the task",
      "default": "created"
    },
    {
      "name": "user_set_state",
      "datatype": "enum",
      "enum_values": ["cancel"],
      "required": false,
      "description": "The user set state of execution of the task",
      "default": null
    },
    {
      "name": "attached_config_lauis",
      "datatype": "array",
      "required": false,
      "default": []
    },
    {
      "name": "config",
      "datatype": "object",
      "required": false,
      "description": "Final config last used after all mishmash",
      "default": {}
    },
    {
      "name": "prev_interval_config",
      "datatype": "object",
      "required": false,
      "description": "Final config last used after all mishmash",
      "default": {}
    },
    {
      "name": "iteration",
      "datatype": "int",
      "required": false,
      "description": "Count of execution of task in its lifetime",
      "default": 0
    },
    {
      "name": "duration",
      "datatype": "int",
      "required": false,
      "description": "Time taken for the task to finish execution",
      "default": null
    },
    {
      "name": "executor",
      "datatype": "string",
      "required": false,
      "description": "Celery worker that executed the task",
      "default": null
    },
    {
      "name": "task_instance",
      "datatype": "string",
      "required": false,
      "description": "Instance on which task is executed",
      "default": null
    },
    {
      "name": "task_reschedule_count",
      "datatype": "int",
      "required": false,
      "description": "How many times task has been rescheduled",
      "default": 0
    },
    {
      "name": "session_id",
      "datatype": "string",
      "required": false,
      "default": null
    },
    {
      "name": "last_run_session_id",
      "datatype": "string",
      "required": false,
      "default": null
    },
    {
      "name": "total_retries",
      "datatype": "int",
      "required": false,
      "default": 0
    },
    {
      "name": "retry_interval",
      "datatype": "int",
      "required": false,
      "default": 0
    },
    {
      "name": "retry_number",
      "datatype": "int",
      "required": false,
      "default": 0
    },
    {
      "name": "priority",
      "datatype": "int",
      "required": false,
      "default": 1
    }
  ],
  "projection_fields" : ["name","partition","frequency","state","actions_status","priority","retry_number","prev_interval_start","logical_date","last_run_date","next_run_date","duration","actions","parent_laui","project_laui"] ,
