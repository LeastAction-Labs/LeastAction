# ============================================================================
# LeastAction environment — OPTIONAL.
#
# You do NOT need this file to run. `docker compose up -d` works out of the box:
# the RSA signing keys are generated on first run and the root login defaults
# to admin@example.com / admin123.
#
# Copy to .env only to override defaults (e.g. set a real root password, point
# at a private registry, or enable AI features).
# ============================================================================

# ── Root admin account (created on first run) ───────────────────────────────
ROOT_EMAIL=admin@example.com
ROOT_USERNAME=admin123
ROOT_PASSWORD=admin123

# ── RSA keypair for JWT signing (OPTIONAL) ──────────────────────────────────
# Leave these unset to have a keypair generated and persisted automatically on
# first run. Set them to bring your own — env values take priority over the
# generated keys/*.pem files. Store each as a single line with literal \n
# between PEM lines, wrapped in double quotes:
#   PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#   PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# PUBLIC_KEY=
# PRIVATE_KEY=

# Public URL the app is reached at (used for CORS / auth redirects).
# Use http://localhost:8080 for a local machine, or http://<server-ip>:8080
# when hosting.
APP_PUBLIC_URL=http://localhost:8080

